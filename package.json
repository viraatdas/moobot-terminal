{
  "name": "moobot-terminal",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:ui": "vite",
    "sidecar": "node sidecar/src/index.ts",
    "build": "tsc && vite build",
    "build:sidecar": "esbuild sidecar/src/index.ts --bundle --platform=node --format=cjs --outfile=src-tauri/resources/sidecar.cjs",
    "build:bundle": "pnpm build && pnpm build:sidecar",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource/instrument-sans": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/martian-mono": "^5.2.7",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "esbuild": "^0.28.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
